FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy Prisma schema and generate client
COPY prisma ./prisma
RUN npx prisma generate

# Copy the rest of the application
COPY . .

# Ensure the database directory exists
RUN mkdir -p /app/prisma/data

EXPOSE 3000

CMD ["npm", "start"]
